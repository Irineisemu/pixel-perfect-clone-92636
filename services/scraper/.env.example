# Conexão com o Postgres do Lovable Cloud (use o transaction pooler)
DATABASE_URL=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Scraping
SCRAPING_BROWSER_POOL_SIZE=3
SCRAPING_DEFAULT_THROTTLE_MS=1000
SCRAPING_USER_AGENT=JusRadar/1.0 (+contato@jusradar.com.br)
RAW_PAYLOAD_LOCAL_PATH=/var/lib/jusradar/raw
INGESTION_CONCURRENCY_SCRAPING=2

# Circuit breaker (mesmos defaults do core)
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_WINDOW_SEC=300
CIRCUIT_BREAKER_OPEN_DURATION_SEC=600

# Loop
TICK_INTERVAL_MS=5000
WORKER_ID=scraper-1
